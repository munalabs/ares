# Ares — Required environment variables
# Copy to ~/.hermes/profiles/pentest/.env and fill in your values.
# This file is a TEMPLATE — never commit the actual .env file.

# ─── Required: LLM provider ────────────────────────────────────────────────
# Anthropic — obtained via `claude login` OAuth flow (Claude Code)
# OR a direct API key from https://console.anthropic.com
# DO NOT set this in the pentest profile .env — it inherits from the default
# Hermes profile which uses the credential pool. Only set here if running
# the pentest profile as a completely standalone instance.
# ANTHROPIC_API_KEY=sk-ant-...

# Google AI Studio — for compression/delegation/fallback (free tier works)
GOOGLE_API_KEY=your-google-ai-studio-key

# ─── ZAP (OWASP ZAP REST API) ──────────────────────────────────────────────
ZAP_API_KEY=your-zap-api-key
ZAP_CONTAINER_IP=172.17.0.3  # docker inspect -f '{{range.NetworkSettings.Networks}}{{.IPAddress}}{{end}}' owasp-zap

# ─── MoBSF (Mobile Security Framework) ────────────────────────────────────
MOBSF_URL=http://172.17.0.1:8100  # docker0 bridge IP — reachable from inside Docker terminal
MOBSF_API_KEY=your-mobsf-api-key  # from: docker logs mobsf 2>&1 | grep -oP 'REST API Key:\s*\K\S+' | tail -1

# ─── Discord gateway ───────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=your-pentest-bot-token
DISCORD_ALLOWED_USERS=your-discord-user-id
DISCORD_FREE_RESPONSE_CHANNELS=your-forum-channel-id

# ─── Hermes tuning ─────────────────────────────────────────────────────────
# Opus 4.6 with xhigh reasoning thinks silently for 3-5 min before first token.
# 180s default kills the connection. 900s gives enough headroom.
HERMES_STREAM_STALE_TIMEOUT=900
