# Ares — Docker Compose environment
# Run ./setup.sh to generate this automatically, or:
#   cp .env.example .env && $EDITOR .env
#   docker compose --project-name ares up -d

# ── Anthropic ─────────────────────────────────────────────────────────────────
# OAuth token from `claude login` — starts with sk-ant-oat01-
# Do NOT use a standard API key — OAuth tokens auto-refresh, static keys go stale.
ANTHROPIC_API_KEY=sk-ant-oat01-REPLACE

# ── Web UI (Open WebUI) ───────────────────────────────────────────────────────
# Open WebUI runs at http://localhost:3000 (no login required by default).
# To enable user accounts (shared/team deployments):
#   WEBUI_AUTH=true
#   WEBUI_SECRET_KEY=<random string>
# To change the host port:
# WEBUI_PORT=3000

# ── Discord (optional) ────────────────────────────────────────────────────────
# Leave all DISCORD_* vars unset for web-UI-only deployment.
# Set them to enable Discord alongside the web UI — both run simultaneously.
#
# Create bot: https://discord.com/developers/applications
# DISCORD_BOT_TOKEN=
# DISCORD_ALLOWED_USERS=
# DISCORD_FREE_RESPONSE_CHANNELS=
# Opus xhigh thinks silently 3-5 min before first token — 900s prevents false timeouts
HERMES_STREAM_STALE_TIMEOUT=900

# ── ZAP ───────────────────────────────────────────────────────────────────────
# Auto-generated by setup.sh. Each engagement spawns its own ZAP container
# (Phase 0) using this key, then tears it down after delivery (Phase 7).
ZAP_API_KEY=REPLACE_WITH_RANDOM_HEX
HERMES_API_KEY=REPLACE_WITH_RANDOM_HEX

# ── Hermes Gateway ────────────────────────────────────────────────────────────
# Required: allows SwarmClaw (and any HTTP API client) to call Hermes without a
# Discord/Telegram allowlist. Safe because the API server requires HERMES_API_KEY auth.
GATEWAY_ALLOW_ALL_USERS=true

# ── MoBSF ─────────────────────────────────────────────────────────────────────
# Auto-extracted by setup.sh after first MoBSF start.
# If setting manually: docker compose --project-name ares logs mobsf | grep "REST API Key"
MOBSF_API_KEY=REPLACE_AFTER_FIRST_START

# ── Output directory ──────────────────────────────────────────────────────────
# Absolute host path. Bind-mounted into hermes container and all terminal containers.
# Each engagement writes to a subdir: $PENTEST_OUTPUT/{target}_{timestamp}/
PENTEST_OUTPUT=${HOME}/ares-pentest-output

# ── Android (optional) ────────────────────────────────────────────────────────
# ADB connects from inside the hermes container to the ADB server on the host.
# The host ADB server must listen on all interfaces before starting the stack:
#   adb kill-server && adb -a -P 5037 nodaemon server start
#
# ADB_SERIAL — the device target the ADB client connects to:
#   Docker emulator (Linux + KVM, --profile android):   localhost:5555
#   Android Studio AVD (macOS/Windows):                 emulator-5554  (verify with `adb devices`)
#   Physical phone over USB (connected to host):        serial from `adb devices` (e.g. R58N12345)
#   Physical phone over Wi-Fi / Tailscale:              <device-ip>:5555
ADB_SERIAL=localhost:5555

# ANDROID_ADB_SERVER_HOST — host where the ADB server is running.
# macOS Docker Desktop: host.docker.internal resolves to 172.17.0.1 (VM bridge, NOT the Mac).
#   Use the Mac's Docker VM interface instead: ifconfig | grep "192.168.64"
#   Typically 192.168.64.1. Run socat to proxy ADB: socat TCP-LISTEN:5038,reuseaddr,fork TCP:127.0.0.1:5037
# Linux with docker0: set to 172.17.0.1
ANDROID_ADB_SERVER_HOST=host.docker.internal
# macOS Docker Desktop: override to 192.168.64.1 (host.docker.internal resolves to VM bridge, not Mac)
# Linux docker0: override to 172.17.0.1

# ANDROID_ADB_SERVER_PORT — port socat/ADB server listens on.
# If using socat proxy on macOS, set to 5038.
ANDROID_ADB_SERVER_PORT=5037

# FRIDA_SERVER_ARCH — CPU architecture of the Android device:
#   x86_64  Linux Docker emulator (--profile android), Android Studio AVD on Intel
#   arm64   Android Studio AVD on Apple Silicon (M1/M2/M3/M4), most physical phones
# setup.sh sets this automatically based on host platform and macOS chip.
# FRIDA_SERVER_ARCH=x86_64

# ── GitHub (optional) ─────────────────────────────────────────────────────────
# GitNexus MCP — needed for private repo analysis only
# GITHUB_TOKEN=ghp_REPLACE
