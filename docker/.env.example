# Ares — Docker Compose environment
# cp .env.example .env && $EDITOR .env
# docker compose --project-name ares up -d

# ── Anthropic ─────────────────────────────────────────────────────────────────
# OAuth token from `claude login` — starts with sk-ant-oat01-
# Do NOT use a standard API key — OAuth tokens auto-refresh, static keys go stale.
ANTHROPIC_API_KEY=sk-ant-oat01-REPLACE

# ── Google AI Studio ──────────────────────────────────────────────────────────
# Compression summaries + non-reasoning delegation. Much cheaper than Opus.
# Get: https://aistudio.google.com/apikey — set a $9 spend cap first.
GOOGLE_API_KEY=REPLACE

# ── Groq ──────────────────────────────────────────────────────────────────────
# Hindsight memory extraction. Free tier.
# Get: https://console.groq.com/keys
GROQ_API_KEY=REPLACE

# ── Discord ───────────────────────────────────────────────────────────────────
# Dedicated bot for the pentest profile (separate from any default Hermes bot).
# One bot token = one active WebSocket. Two profiles need two bots.
# Create: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=REPLACE
# Your Discord user ID (right-click profile → Copy User ID)
DISCORD_ALLOWED_USERS=REPLACE
# Forum channel ID for engagements (right-click forum channel → Copy ID)
DISCORD_FREE_RESPONSE_CHANNELS=REPLACE
# Opus xhigh thinks silently 3-5 min before first token — 900s prevents false timeouts
HERMES_STREAM_STALE_TIMEOUT=900

# ── ZAP ───────────────────────────────────────────────────────────────────────
# ZAP is NOT a compose service — each engagement spawns its own ZAP container
# (Phase 0) and tears it down after delivery (Phase 7).
# This key is passed into terminal containers and used when spawning ZAP.
# Generate: openssl rand -hex 16
ZAP_API_KEY=REPLACE_WITH_RANDOM_HEX

# ── MoBSF ─────────────────────────────────────────────────────────────────────
# Extract after first MoBSF start:
#   docker compose --project-name ares logs mobsf | grep "REST API Key"
# Add value here, then: docker compose --project-name ares restart hermes
MOBSF_API_KEY=REPLACE_AFTER_FIRST_START

# ── Output directory ──────────────────────────────────────────────────────────
# Absolute host path. Bind-mounted into hermes container and all terminal containers.
# Each engagement writes to a subdir: $PENTEST_OUTPUT/{target}_{timestamp}/
PENTEST_OUTPUT=/opt/ares/pentest-output

# ── Android (optional) ────────────────────────────────────────────────────────
# ADB target. Docker emulator default: localhost:5555
# Physical device over WiFi/Tailscale: <device-ip>:5555
ADB_SERIAL=localhost:5555

# ── GitHub (optional) ─────────────────────────────────────────────────────────
# GitNexus MCP — needed for private repo analysis only
# GITHUB_TOKEN=ghp_REPLACE
